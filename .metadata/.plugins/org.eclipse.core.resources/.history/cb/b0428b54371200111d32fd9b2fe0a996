package com.financial.demo.service;

import org.springframework.stereotype.Service;

import com.financial.demo.dto.FinancialRequestDTO;
import com.financial.demo.dto.FinancialResponseDTO;
import com.financial.demo.entity.FinancialStatement;
import com.financial.demo.feign.CustomerClient;
import com.financial.demo.repository.FinancialRepository;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class FinancialService {

    private final FinancialRepository repository;
  //  private final CustomerClient customerClient;

    public FinancialResponseDTO create(FinancialRequestDTO dto) {

        // Validate customer exists
    //    customerClient.getCustomer(dto.getCustomerId());

        FinancialStatement statement = FinancialStatement.builder()
                .customerId(dto.getCustomerId())
                .financialYear(dto.getFinancialYear())
                .totalAssets(dto.getTotalAssets())
                .totalLiabilities(dto.getTotalLiabilities())
                .totalEquity(dto.getTotalEquity())
                .revenue(dto.getRevenue())
                .netProfit(dto.getNetProfit())
                .currentAssets(dto.getCurrentAssets())
                .currentLiabilities(dto.getCurrentLiabilities())
                .interestExpense(dto.getInterestExpense())
                .ebit(dto.getEbit())
                .build();

        FinancialStatement saved = repository.save(statement);

        return mapToDTO(saved);
    }

    public FinancialResponseDTO getByCustomerAndYear(Long customerId, Integer year) {

        FinancialStatement statement =
                repository.findByCustomerIdAndFinancialYear(customerId, year)
                        .orElseThrow(() -> new RuntimeException("Financial data not found"));

        return mapToDTO(statement);
    }

    private FinancialResponseDTO mapToDTO(FinancialStatement s) {
        return FinancialResponseDTO.builder()
                .id(s.getId())
                .customerId(s.getCustomerId())
                .financialYear(s.getFinancialYear())
                .totalAssets(s.getTotalAssets())
                .totalLiabilities(s.getTotalLiabilities())
                .totalEquity(s.getTotalEquity())
                .revenue(s.getRevenue())
                .netProfit(s.getNetProfit())
                .currentAssets(s.getCurrentAssets())
                .currentLiabilities(s.getCurrentLiabilities())
                .interestExpense(s.getInterestExpense())
                .ebit(s.getEbit())
                .build();
    }
}