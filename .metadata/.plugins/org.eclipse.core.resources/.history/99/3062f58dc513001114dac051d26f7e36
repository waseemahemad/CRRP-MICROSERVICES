package com.riskassessment.demo.service;

import org.springframework.stereotype.Service;

import com.riskassessment.demo.dto.FinancialResponseDTO;
import com.riskassessment.demo.dto.RiskResponseDTO;
import com.riskassessment.demo.entity.RiskAssessment;
import com.riskassessment.demo.feign.FinancialClient;
import com.riskassessment.demo.repository.RiskRepository;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class RiskService {

    private final FinancialClient financialClient;
    private final RiskRepository repository;

    public RiskResponseDTO assessRisk(Long customerId, Integer year) {

        FinancialResponseDTO financial =
                financialClient.getFinancial(customerId, year);

        if (financial == null) {
            throw new RuntimeException("Financial data not found");
        }

        double totalLiabilities = getSafe(financial.getTotalLiabilities());
        double totalEquity = getSafe(financial.getTotalEquity());
        double currentAssets = getSafe(financial.getCurrentAssets());
        double currentLiabilities = getSafe(financial.getCurrentLiabilities());
        double ebit = getSafe(financial.getEbit());
        double interestExpense = getSafe(financial.getInterestExpense());
        double netProfit = getSafe(financial.getNetProfit());
        double revenue = getSafe(financial.getRevenue());

        if (totalEquity == 0 || currentLiabilities == 0 
            || interestExpense == 0 || revenue == 0) {
            throw new IllegalArgumentException("Invalid financial values for ratio calculation");
        }

        double debtToEquity = totalLiabilities / totalEquity;
        double currentRatio = currentAssets / currentLiabilities;
        double interestCoverage = ebit / interestExpense;
        double profitMargin = netProfit / revenue;

        int score = calculateScore(debtToEquity,
                                   currentRatio,
                                   interestCoverage,
                                   profitMargin);

        String level = determineRiskLevel(score);

        RiskAssessment assessment = RiskAssessment.builder()
                .customerId(customerId)
                .financialYear(year)
                .debtToEquity(debtToEquity)
                .currentRatio(currentRatio)
                .interestCoverage(interestCoverage)
                .profitMargin(profitMargin)
                .riskScore(score)
                .riskLevel(level)
                .build();

        repository.save(assessment);

        return mapToDTO(assessment);
    }
    private double getSafe(Double value) {
        return value == null ? 0.0 : value;
    }

    private RiskResponseDTO calculateAndSave(Long customerId, Integer year) {

        FinancialResponseDTO financial =
                financialClient.getFinancial(customerId, year);

        // Calculate Ratios
        double debtToEquity =
                financial.getTotalLiabilities() / financial.getTotalEquity();

        double currentRatio =
                financial.getCurrentAssets() / financial.getCurrentLiabilities();

        double interestCoverage =
                financial.getEbit() / financial.getInterestExpense();

        double profitMargin =
                financial.getNetProfit() / financial.getRevenue();

        // Risk Score Logic
        int score = calculateScore(
                debtToEquity,
                currentRatio,
                interestCoverage,
                profitMargin
        );

        String level = determineRiskLevel(score);

        RiskAssessment assessment = RiskAssessment.builder()
                .customerId(customerId)
                .financialYear(year)
                .debtToEquity(debtToEquity)
                .currentRatio(currentRatio)
                .interestCoverage(interestCoverage)
                .profitMargin(profitMargin)
                .riskScore(score)
                .riskLevel(level)
                .build();

        repository.save(assessment);

        return mapToDTO(assessment);
    }

    private int calculateScore(double dte,
                               double cr,
                               double ic,
                               double pm) {

        int score = 0;

        if (dte < 1) score += 25;
        else if (dte < 2) score += 15;

        if (cr > 2) score += 25;
        else if (cr > 1) score += 15;

        if (ic > 3) score += 25;
        else if (ic > 1.5) score += 15;

        if (pm > 0.15) score += 25;
        else if (pm > 0.05) score += 15;

        return score;
    }

    private String determineRiskLevel(int score) {

        if (score >= 80) return "LOW";
        if (score >= 50) return "MEDIUM";
        return "HIGH";
    }

    private RiskResponseDTO mapToDTO(RiskAssessment r) {

        return RiskResponseDTO.builder()
                .customerId(r.getCustomerId())
                .financialYear(r.getFinancialYear())
                .debtToEquity(r.getDebtToEquity())
                .currentRatio(r.getCurrentRatio())
                .interestCoverage(r.getInterestCoverage())
                .profitMargin(r.getProfitMargin())
                .riskScore(r.getRiskScore())
                .riskLevel(r.getRiskLevel())
                .build();
    }
}