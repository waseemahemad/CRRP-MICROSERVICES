package com.riskassessment.demo.service;

import org.springframework.stereotype.Service;
import lombok.RequiredArgsConstructor;

import com.riskassessment.demo.dto.RiskResponseDTO;
import com.riskassessment.demo.dto.FinancialResponseDTO;
import com.riskassessment.demo.entity.RiskAssessment;
import com.riskassessment.demo.feign.FinancialClient;
import com.riskassessment.demo.repository.RiskRepository;

import jakarta.transaction.Transactional;

@Service
@RequiredArgsConstructor
public class RiskService {

    private final RiskRepository repository;
    private final FinancialClient financialClient;

    @Transactional  public RiskResponseDTO assessRisk(Long customerId, Integer year) {

        FinancialResponseDTO financial =
                financialClient.getFinancial(customerId, year);

        if (financial == null) {
            throw new RuntimeException("Financial data not found");
        }

        validateFinancialData(financial);

        double debtToEquity =
                financial.getTotalLiabilities() / financial.getTotalEquity();

        double currentRatio =
                financial.getCurrentAssets() / financial.getCurrentLiabilities();

        double interestCoverage =
                financial.getEbit() / financial.getInterestExpense();

        double profitMargin =
                financial.getNetProfit() / financial.getRevenue();

        int score = calculateScore(
                debtToEquity,
                currentRatio,
                interestCoverage,
                profitMargin
        );

        String riskLevel = determineRiskLevel(score);

        RiskAssessment assessment = RiskAssessment.builder()
                .customerId(customerId)
                .financialYear(year)
                .debtToEquity(debtToEquity)
                .currentRatio(currentRatio)
                .interestCoverage(interestCoverage)
                .profitMargin(profitMargin)
                .riskScore(score)
                .riskLevel(riskLevel)
                .build();

        repository.save(assessment);

        return mapToDTO(assessment);
    }

    private void validateFinancialData(FinancialResponseDTO f) {

        if (f.getTotalEquity() == null || f.getTotalEquity() == 0)
            throw new IllegalArgumentException("Invalid Total Equity");

        if (f.getCurrentLiabilities() == null || f.getCurrentLiabilities() == 0)
            throw new IllegalArgumentException("Invalid Current Liabilities");

        if (f.getInterestExpense() == null || f.getInterestExpense() == 0)
            throw new IllegalArgumentException("Invalid Interest Expense");

        if (f.getRevenue() == null || f.getRevenue() == 0)
            throw new IllegalArgumentException("Invalid Revenue");

        if (f.getTotalLiabilities() == null ||
            f.getCurrentAssets() == null ||
            f.getEbit() == null ||
            f.getNetProfit() == null)
            throw new IllegalArgumentException("Missing required financial data");
    }

    private int calculateScore(double debtToEquity,
                               double currentRatio,
                               double interestCoverage,
                               double profitMargin) {

        int score = 0;

        if (debtToEquity < 1) score += 25;
        else if (debtToEquity < 2) score += 15;
        else score += 5;

        if (currentRatio >= 2) score += 25;
        else if (currentRatio >= 1) score += 15;
        else score += 5;

        if (interestCoverage >= 5) score += 25;
        else if (interestCoverage >= 2) score += 15;
        else score += 5;

        if (profitMargin >= 0.20) score += 25;
        else if (profitMargin >= 0.10) score += 15;
        else score += 5;

        return score;
    }

    private String determineRiskLevel(int score) {

        if (score >= 80) return "LOW";
        else if (score >= 50) return "MEDIUM";
        else return "HIGH";
    }

    private RiskResponseDTO mapToDTO(RiskAssessment assessment) {

        return RiskResponseDTO.builder()
                .customerId(assessment.getCustomerId())
                .financialYear(assessment.getFinancialYear())
                .debtToEquity(assessment.getDebtToEquity())
                .currentRatio(assessment.getCurrentRatio())
                .interestCoverage(assessment.getInterestCoverage())
                .profitMargin(assessment.getProfitMargin())
                .riskScore(assessment.getRiskScore())
                .riskLevel(assessment.getRiskLevel())
                .build();
    }
}