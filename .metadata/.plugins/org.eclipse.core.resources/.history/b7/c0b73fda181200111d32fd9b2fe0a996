package com.example.demo.service;
@Service
@RequiredArgsConstructor
public class LoanService {

    private final LoanRepository repository;
    private final RiskClient riskClient;
    private final RatingClient ratingClient;

    public LoanResponseDTO processLoan(LoanRequestDTO request) {

        RiskResponseDTO risk =
                riskClient.assess(
                        request.getCustomerId(),
                        request.getFinancialYear());

        RatingResponseDTO rating =
                ratingClient.getRating(
                        request.getCustomerId(),
                        request.getFinancialYear());

        String decision;
        double approvedAmount = 0;
        double interestRate = 0;

        if ("LOW".equals(risk.getRiskLevel())) {
            decision = "APPROVED";
            approvedAmount = request.getRequestedAmount();
            interestRate = 8.0;

        } else if ("MEDIUM".equals(risk.getRiskLevel())) {
            decision = "APPROVED";
            approvedAmount = request.getRequestedAmount() * 0.8;
            interestRate = 11.0;

        } else {
            decision = "REJECTED";
        }

        LoanApplication application = LoanApplication.builder()
                .customerId(request.getCustomerId())
                .financialYear(request.getFinancialYear())
                .requestedAmount(request.getRequestedAmount())
                .approvedAmount(approvedAmount)
                .interestRate(interestRate)
                .riskLevel(risk.getRiskLevel())
                .rating(rating.getRating())
                .decisionStatus(decision)
                .build();

        repository.save(application);

        return LoanResponseDTO.builder()
                .customerId(request.getCustomerId())
                .requestedAmount(request.getRequestedAmount())
                .approvedAmount(approvedAmount)
                .interestRate(interestRate)
                .riskLevel(risk.getRiskLevel())
                .rating(rating.getRating())
                .decisionStatus(decision)
                .build();
    }
}